#!/bin/bash
CYAN='\033[0;36m'
RED='\033[0;31m'
NC='\033[0m'
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# ------------------------
# PATH management functions
# ------------------------
add_path_to_bashrc() {
    START="# >>> Pyra Tool PATH >>>"
    END="# <<< Pyra Tool PATH <<<"
    if ! grep -q "$START" ~/.bashrc; then
        echo -e "${CYAN}Adding Pyra directories to PATH in ~/.bashrc${NC}"
        echo "$START" >> ~/.bashrc
        cat >> ~/.bashrc <<'EOF'
# my additions_____________________________________
# Cyberpunk cyan color scheme for ls
LS_COLORS=$LS_COLORS:'di=1;38;5;51:'   # Directories in bold bright cyan
LS_COLORS=$LS_COLORS:'ex=1;38;5;46:'   # Executables in bright green
LS_COLORS=$LS_COLORS:'ln=1;38;5;201:'  # Symlinks in magenta
LS_COLORS=$LS_COLORS:'*.sh=38;5;45:'   # Shell scripts in cyan-blue
LS_COLORS=$LS_COLORS:'*.py=38;5;45:'   # Python files in cyan-blue
LS_COLORS=$LS_COLORS:'*.txt=38;5;240:' # Text files in dark grey
LS_COLORS=$LS_COLORS:'or=1;38;5;196:'  # Broken symlinks in red (warning)
LS_COLORS=$LS_COLORS:'mi=1;38;5;196:'  # Missing files in red (warning)
export LS_COLORS

function start_shell_or_venv() {

    # === CYBERPUNK COLOR PALETTE ===
    CYAN="\033[38;5;51m"
    CYAN_DIM="\033[38;5;45m"
    CYAN_DARK="\033[38;5;30m"
    GREEN="\033[38;5;46m"
    GREEN_DIM="\033[38;5;34m"
    MAGENTA="\033[38;5;201m"
    YELLOW="\033[38;5;226m"
    WHITE="\033[38;5;231m"
    GREY="\033[38;5;240m"
    RESET="\033[0m"
    BOLD="\033[1m"
    BLINK="\033[5m"

    # === SPINNER FUNCTION ===
    spin() {
        local pid=$1
        local delay=0.07
        local spinstr='|/-'
        local i=0
        while kill -0 "$pid" 2>/dev/null; do
            local char="${spinstr:$i:1}"
            echo -ne "\r ${CYAN}${char}${RESET}"
            i=$(( (i+1) % ${#spinstr} ))
            sleep $delay
        done
        echo -ne "\r   \r"
    }

    # === SCROLLING HACKER PHRASES ===
    scroll_phrases() {
        local phrases=(
            "// there is no patch for human stupidity"
            "rm -rf /bad_decisions"
            "sudo make me a sandwich"
            "git commit -m 'fixed the thing'"
            "// it works on my machine"
            "while true; do coffee; done"
            "grep -r 'meaning' /life  # no results"
            "cat /dev/urandom | grep sanity"
            "alias reality='vim /etc/simulation'"
            "chmod 777 /my/soul"
            "ERROR: keyboard not found — press F1 to continue"
            "// TODO: sleep someday"
            "ping -c 1 existence  # host unreachable"
            "echo 'hello world' >> /dev/null"
            "ssh root@mainframe -i ~/.ssh/vibes"
            "// segfault is just the computer crying"
            "sudo apt install motivation  # package not found"
            "kill -9 \$(pgrep -f impostor_syndrome)"
            "traceroute to enlightenment... timed out"
            "git push origin chaos"
        )

        local phrase="${phrases[$((RANDOM % ${#phrases[@]}))]}"
        local len=${#phrase}
        local cols=$(tput cols 2>/dev/null || echo 80)
        local pad=$(( (cols - len) / 2 ))
        [ $pad -lt 0 ] && pad=0

        # scroll right to left across the line
        local scroll_width=$(( cols + len ))
        echo ""
        for (( pos=cols; pos>=-len; pos-=2 )); do
            local spaces=""
            if [ $pos -gt 0 ]; then
                spaces=$(printf '%*s' "$pos" '')
            fi
            echo -ne "\r${GREY}${spaces}${GREEN_DIM}${phrase}${RESET}   "
            sleep 0.018
        done
        echo -ne "\r$(printf '%*s' "$cols" '')  \r"
    }

    # === BOOT SEQUENCE ===
    boot_sequence() {
        local msgs=(
            "INITIALIZING NEURAL LINK............"
            "BYPASSING ICE LAYER................."
            "AUTHENTICATING RETINAL SCAN........."
            "DECRYPTING KERNEL MANIFOLD.........."
            "JACKING INTO THE GRID..............."
        )
        for msg in "${msgs[@]}"; do
            echo -ne " ${CYAN_DIM}${msg}${RESET}"
            sleep 0.12
            echo -e " ${GREEN}[OK]${RESET}"
        done
    }

    # === GLITCH EFFECT ON TEXT ===
    glitch_print() {
        local text="$1"
        local color="$2"
        local glitch_chars='!@#$%^&*<>?/|\\~`'
        echo -ne " ${color}"
        for (( i=0; i<${#text}; i++ )); do
            local ch="${text:$i:1}"
            if [[ "$ch" != " " ]] && (( RANDOM % 6 == 0 )); then
                local gc="${glitch_chars:$((RANDOM % ${#glitch_chars})):1}"
                echo -ne "${MAGENTA}${gc}${color}"
                sleep 0.01
                echo -ne "\b${ch}"
            else
                echo -ne "${ch}"
            fi
            sleep 0.005
        done
        echo -e "${RESET}"
    }

    # === CYAN ASCII ART: "CYON" ===
    print_cyon() {
        echo -e "${CYAN}${BOLD}"
        echo -e "   ██████╗██╗   ██╗ ██████╗ ███╗   ██╗"
        echo -e "  ██╔════╝╚██╗ ██╔╝██╔═══██╗████╗  ██║"
        echo -e "  ██║      ╚████╔╝ ██║   ██║██╔██╗ ██║"
        echo -e "  ██║       ╚██╔╝  ██║   ██║██║╚██╗██║"
        echo -e "  ╚██████╗   ██║   ╚██████╔╝██║ ╚████║"
        echo -e "   ╚═════╝   ╚═╝    ╚═════╝ ╚═╝  ╚═══╝"
        echo -e "${RESET}"
    }

    # === DECORATIVE BORDER ===
    cyber_border() {
        local cols=$(tput cols 2>/dev/null || echo 80)
        local border=""
        for (( i=0; i<cols-2; i++ )); do
            if (( i % 4 == 0 )); then border+="▓"
            elif (( i % 4 == 1 )); then border+="░"
            elif (( i % 4 == 2 )); then border+="▒"
            else border+="░"; fi
        done
        echo -e " ${CYAN_DARK}${border}${RESET}"
    }

    # ============================================================
    # MAIN INTRO SEQUENCE
    # ============================================================
    clear

    cyber_border

    # Spinning boot loader
    (sleep 1.2) &
    local boot_pid=$!
    echo -ne " ${CYAN}SYSTEM BOOT${RESET}"
    spin $boot_pid
    wait $boot_pid

    boot_sequence
    sleep 0.1
    scroll_phrases
    sleep 0.1

    cyber_border
    print_cyon
    cyber_border

    # Glitchy tagline
    glitch_print "  ░ L I N U X ░  [ CYBERDECK ONLINE ]" "${CYAN}"
    echo ""

    # ============================================================
    # MAIN MENU LOOP
    # ============================================================
    while true; do
        local user=$USER
        local current_dir=$PWD
        local pc_name=$HOSTNAME

        # Pulse spinner beside menu header
        echo -e "\n ${CYAN}▓▒░ ${WHITE}COMMAND MATRIX${CYAN} ░▒▓${RESET}"
        echo -e " ${CYAN_DIM}┌─────────────────────────┐${RESET}"
        echo -e " ${CYAN_DIM}│${CYAN}  ⟁  ${WHITE}shell${RESET}             ${CYAN_DIM}│${RESET}"
        echo -e " ${CYAN_DIM}│${CYAN}  ⟁  ${WHITE}start tinycrux${RESET}    ${CYAN_DIM}│${RESET}"
        echo -e " ${CYAN_DIM}│${CYAN}  ⟁  ${WHITE}stop tinycrux${RESET}     ${CYAN_DIM}│${RESET}"
        echo -e " ${CYAN_DIM}│${CYAN}  ⟁  ${WHITE}pyra_env${RESET}          ${CYAN_DIM}│${RESET}"
        echo -e " ${CYAN_DIM}│${CYAN}  ⟁  ${WHITE}pyserver${RESET}          ${CYAN_DIM}│${RESET}"
        echo -e " ${CYAN_DIM}│${CYAN}  ⟁  ${WHITE}pi ssh${RESET}            ${CYAN_DIM}│${RESET}"
        echo -e " ${CYAN_DIM}│${CYAN}  ⟁  ${WHITE}droid ssh${RESET}         ${CYAN_DIM}│${RESET}"
        echo -e " ${CYAN_DIM}│${MAGENTA}  ⟁  ${WHITE}exit${RESET}              ${CYAN_DIM}│${RESET}"
        echo -e " ${CYAN_DIM}└─────────────────────────┘${RESET}"
        echo -e " ${CYAN_DARK}____________________________${RESET}"
        echo -ne " ${CYAN}┌░${RESET}${current_dir}${CYAN}░${RESET}\n ${CYAN}└░${RESET}${user}${CYAN}@${RESET}${pc_name}"
        read -p "░ " input

        case "$input" in
          "shell")
            scroll_phrases
            neofetch
            echo -e " ${CYAN}$(date)${RESET}"
            break
            ;;
          "start tinycrux")
            glitch_print "  INITIATING TINYCRUX UPLINK..." "${CYAN}"
            (sleep 0.8) & spin $!; wait $!
            sudo systemctl start ollama
            ollama run phi3
            break
            ;;
          "stop tinycrux")
            glitch_print "  SEVERING TINYCRUX LINK..." "${MAGENTA}"
            (sleep 0.6) & spin $!; wait $!
            sudo systemctl stop ollama
            break
            ;;
          "pyra_env")
            glitch_print "  LOADING PYRA VIRTUAL ENV..." "${GREEN}"
            (sleep 0.8) & spin $!; wait $!
            scroll_phrases
            neofetch
            echo -e " ${CYAN}$(date)${RESET}"
            source ~/pyra_env/bin/activate
            echo -e "${CYAN} executables:\n  pyra_toolz\n${RESET}"
            break
            ;;
          "pyserver")
            glitch_print "  SPINNING UP PYTHON SERVER..." "${GREEN}"
            (sleep 0.5) & spin $!; wait $!
            python3 -m http.server -b 0.0.0.0
            break
            ;;
          "pi ssh")
            glitch_print "  ESTABLISHING SECURE CHANNEL TO PI..." "${CYAN}"
            (sleep 0.5) & spin $!; wait $!
            ssh user@192.168.1.000
            break
            ;;
          "droid ssh")
            glitch_print "  JACKING INTO DROID NODE..." "${CYAN}"
            (sleep 0.5) & spin $!; wait $!
            ssh user@192.168.1.000 -p 8022
            break
            ;;
          "exit")
            glitch_print "  DISCONNECTING FROM THE GRID..." "${MAGENTA}"
            (sleep 0.5) & spin $!; wait $!
            echo -e " ${GREY}// goodbye, operator.${RESET}\n"
            exit
            ;;
          *)
            echo -e " ${MAGENTA}ERROR:${RESET} ${GREY}// unknown command — try again, operator${RESET}"
            ;;
        esac
    done
}

start_shell_or_venv
for dir in "$HOME/cyon/bin" "$HOME/cyon/pyra_tool"; do
    if [ -d "$dir" ]; then
        case ":$PATH:" in
            *":$dir:"*) ;;
            *) PATH="$PATH:$dir" ;;
        esac
    fi
done
export PATH
echo -e "\033[0;36m executables:\n cyon_cli\n pyra_toolz\n pyra_termux\033[0m"
export PATH
EOF
        echo "$END" >> ~/.bashrc
    else
        echo -e "${CYAN}Pyra PATH already exists in ~/.bashrc${NC}"
    fi
}
remove_path_from_bashrc() {
    START="# >>> Pyra Tool PATH >>>"
    END="# <<< Pyra Tool PATH <<<"
    if grep -q "$START" ~/.bashrc; then
        echo -e "${RED}Removing Pyra PATH from ~/.bashrc${NC}"
        sed -i "/$START/,/$END/d" ~/.bashrc
    else
        echo -e "${CYAN}No Pyra PATH found in ~/.bashrc${NC}"
    fi
}
# ------------------------
# Build & setup functions
# ------------------------
install_desktop_dependencies() {
    echo -e "${CYAN} Installing dependencies...${NC}"
    sudo apt update && sudo apt upgrade -y
    sudo apt install -y build-essential libgtk-3-dev pkg-config curl yt-dlp ffmpeg
    sudo apt install -y python3-gi python3-gi-cairo gir1.2-gtk-3.0
}
compile_cyon_desktop() {
    echo -e "${CYAN} Compiling C binaries...${NC}"
    mkdir -p "$SCRIPT_DIR/bin"
    gcc -I"$SCRIPT_DIR/include" \
    "$SCRIPT_DIR/src/main_cyon.c" \
    "$SCRIPT_DIR/src/downloader.c" \
    -o "$SCRIPT_DIR/bin/main_cyon" \
    $(pkg-config --cflags --libs gtk+-3.0) -lpthread
    gcc -I"$SCRIPT_DIR/include" -o "$SCRIPT_DIR/bin/cyon_cli" "$SCRIPT_DIR/cli/cyon_cli.c" || { echo -e "${RED} Failed to compile cyon_cli${NC}"; exit 1; }
    gcc -I"$SCRIPT_DIR/include" -o "$SCRIPT_DIR/bin/watcher" "$SCRIPT_DIR/cli/watcher.c" || { echo -e "${RED} Failed to compile watcher${NC}"; exit 1; }
    gcc -I"$SCRIPT_DIR/include" -o "$SCRIPT_DIR/bin/cyon_netscan" "$SCRIPT_DIR/cli/cyon_netscan.c" || { echo -e "${RED} Failed to compile cyon_netscan${NC}"; exit 1; }
    mkdir -p ~/.local/share/applications
    tee ~/.local/share/applications/cyon.desktop > /dev/null <<EOF
[Desktop Entry]
Type=Application
Encoding=UTF-8
Name=Cyon
Comment=Cyon DE
Exec=$SCRIPT_DIR/bin/main_cyon
#Icon=$SCRIPT_DIR/bin/cyon.png
Icon=$SCRIPT_DIR/bin/main_cyon.webp
Terminal=false
Categories=Application;
EOF
    
    update-desktop-database ~/.local/share/applications
    echo -e "${CYAN} Cyon desktop compiled successfully.${NC}"
}
compile_cyon_shell() {
    echo -e "${CYAN} Compiling cyon_shell...${NC}"
    mkdir -p "$SCRIPT_DIR/bin"
    gcc -I"$SCRIPT_DIR/include" \
    "$SCRIPT_DIR/src/main_cyon_shell.c" \
    "$SCRIPT_DIR/src/downloader.c" \
    -o "$SCRIPT_DIR/bin/main_cyon_shell" \
    $(pkg-config --cflags --libs gtk+-3.0) -lpthread || { echo -e "${RED} Failed to compile main_cyon_shell${NC}"; exit 1; }
    mkdir -p ~/.local/share/applications
    tee ~/.local/share/applications/cyon_shell.desktop > /dev/null <<EOF
[Desktop Entry]
Type=Application
Encoding=UTF-8
Name=Cyon Shell
Comment=Cyon Shell Panel
Exec=$SCRIPT_DIR/bin/main_cyon_shell
Icon=$SCRIPT_DIR/bin/main_cyon.webp
Terminal=false
Categories=Utility;Accessories;
EOF
    update-desktop-database ~/.local/share/applications
    echo -e "${CYAN} cyon_shell compiled successfully.${NC}"
}
setup_pyra_env() {
    echo -e "${CYAN} Setting up pyra_env...${NC}"
    sudo apt install -y python3-gi python3-gi-cairo gir1.2-gtk-3.0
    python3 -m venv --system-site-packages ~/pyra_env
    source ~/pyra_env/bin/activate
    pip3 install --upgrade pip
    pip3 install pyfiglet moviepy rich pillow cryptography pyautogui
    deactivate
    echo -e "${CYAN} pyra_env ready at ~/pyra_env${NC}"
    install_piper_binary
    setup_piper_models
}

install_piper_binary() {
    echo -e "${CYAN} Installing Piper TTS...${NC}"

    sudo apt update
    sudo apt install -y python3-pip ffmpeg libsndfile1
    sudo apt install -y alsa-utils pulseaudio-utils

    ~/pyra_env/bin/pip install --upgrade piper-tts onnxruntime pathvalidate

    echo -e "${CYAN} Piper installed into pyra_env.${NC}"
}

setup_piper_models() {
    echo -e "${CYAN} Downloading Piper voice models...${NC}"

    mkdir -p ~/cyon/piper_models
    cd ~/cyon/piper_models || exit

    # Joe voice
    wget -O en_US-joe-medium.onnx \
    "https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/en/en_US/joe/medium/en_US-joe-medium.onnx?download=true"

    wget -O en_US-joe-medium.onnx.json \
    "https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/en/en_US/joe/medium/en_US-joe-medium.onnx.json?download=true"

    # Lessac voice
    wget -O en_US-lessac-medium.onnx \
    "https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/en/en_US/lessac/medium/en_US-lessac-medium.onnx?download=true"

    wget -O en_US-lessac-medium.onnx.json \
    "https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/en/en_US/lessac/medium/en_US-lessac-medium.onnx.json?download=true"

    echo -e "${CYAN} Piper voices installed in ~/piper_models${NC}"

    source ~/pyra_env/bin/activate
}

compile_cyon_notes() {
    echo -e "${CYAN} Compiling cyon_notes...${NC}"
    mkdir -p "$SCRIPT_DIR/bin"
    gcc $(pkg-config --cflags gtk+-3.0) -o "$SCRIPT_DIR/bin/cyon_notes" "$SCRIPT_DIR/src/cyon_notes.c" $(pkg-config --libs gtk+-3.0) -lpthread || { echo -e "${RED} Failed to compile cyon_notes${NC}"; exit 1; }
    mkdir -p ~/.local/share/applications
    tee ~/.local/share/applications/cyon_notes.desktop > /dev/null <<EOF
[Desktop Entry]
Version=1.0
Type=Application
Encoding=UTF-8
Name=Cyon Notes
Comment=Cyon Notes editor with TTS
Exec=$SCRIPT_DIR/bin/cyon_notes %F
Icon=$SCRIPT_DIR/bin/cyon.png
Terminal=false
Categories=TextEditor;Utility;
MimeType=text/plain;text/x-csrc;text/x-chdr;text/markdown;text/x-log;text/x-python;text/x-shellscript;
StartupNotify=false
EOF
    
    update-desktop-database ~/.local/share/applications
    echo -e "${CYAN} cyon_notes compiled successfully.${NC}"
}
compile_pyra_toolz() {
    echo -e "${CYAN} Compiling pyra_toolz...${NC}"
    sudo apt install -y yt-dlp
    cd && mkdir ~/pyra_temp && cd ~/pyra_temp && python3 -m venv .
    source ~/pyra_temp/bin/activate
    pip3 install pyinstaller rich pillow cryptography
    sudo apt update && sudo apt upgrade -y
    cd ~/cyon/pyra_tool
    echo -e "${RED} Compiling pyra_toolz...\n${NC}"
    pyinstaller --onefile --collect-all rich --name pyra_toolz main.py || { echo -e "${RED} Failed to compile pyra_toolz${NC}"; deactivate; exit 1; }
    deactivate
    cd && rm -rf ~/pyra_temp
    cp ~/cyon/pyra_tool/dist/pyra_toolz ~/cyon/pyra_tool
    chmod +x ~/cyon/pyra_tool/pyra_toolz
    rm -rf ~/cyon/pyra_tool/dist && rm -rf ~/cyon/pyra_tool/build
    echo -e "${CYAN} pyra_toolz compiled successfully.${NC}"
}
compile_pyra_termux() {
    echo -e "${CYAN} Compiling pyra_termux...${NC}"
    apt install -y yt-dlp
    cd && mkdir ~/pyra_temp && cd ~/pyra_temp && python3 -m venv .
    source ~/pyra_temp/bin/activate
    pip3 install rich pyinstaller cryptography
    apt update && apt upgrade -y
    cd ~/cyon/pyra_tool
    echo -e "${RED} Compiling pyra_termux...\n${NC}"
    pyinstaller --onefile --collect-all rich --name pyra_termux main.py || { echo -e "${RED} Failed to compile pyra_termux${NC}"; deactivate; exit 1; }
    deactivate
    cd && rm -rf ~/pyra_temp
    cp -r ~/cyon/pyra_tool/dist/* ~/cyon/pyra_tool
    rm -rf ~/cyon/pyra_tool/dist && rm -rf ~/cyon/pyra_tool/build
    chmod +x ~/cyon/pyra_tool/pyra_termux
    echo -e "${CYAN} pyra_termux compiled successfully.${NC}"
}
remove_cyon_shell() {
    echo -e "${RED} Removing cyon_shell...${NC}"
    rm -f ~/.local/share/applications/cyon_shell.desktop
    rm -f "$SCRIPT_DIR/bin/main_cyon_shell"
    if command -v update-desktop-database &>/dev/null; then
        update-desktop-database ~/.local/share/applications
    fi
    echo -e "${CYAN} cyon_shell removed.${NC}"
}
uninstall_cyon() {
    echo -e "${RED} ==============================${NC}"
    echo -e "${RED}    Cyon Uninstaller${NC}"
    echo -e "${RED} ==============================${NC}"
    echo -e "${RED} This will completely remove Cyon from your system.${NC}"
    echo ""
    read -p $' \033[0;31mAre you sure? This cannot be undone. [y/N]: \033[0m' confirm
    case "$confirm" in
        [yY][eE][sS]|[yY])
            echo -e "${RED} Removing Pyra PATH from ~/.bashrc...${NC}"
            remove_path_from_bashrc
            echo -e "${RED} Removing desktop entry...${NC}"
            rm -f ~/.local/share/applications/cyon.desktop
            rm -f ~/.local/share/applications/cyon_notes.desktop
            rm -f ~/.local/share/applications/cyon_shell.desktop
            if command -v update-desktop-database &>/dev/null; then
                update-desktop-database ~/.local/share/applications
            fi
            echo -e "${RED} Removing pyra_env...${NC}"
            rm -rf ~/pyra_env
            echo -e "${RED} Removing Cyon directory...${NC}"
            rm -rf "$SCRIPT_DIR"
            echo -e "${CYAN} Cyon has been fully removed. Goodbye!${NC}"
            exit 0
            ;;
        *)
            echo -e "${CYAN} Uninstall cancelled.${NC}"
            ;;
    esac
}
